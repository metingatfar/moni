# MONI - Environment Variables Template
NODE_ENV=production
VITE_PORT=3001

# Cloud AI API Keys (Optional, falls back to local models if empty or offline)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# Backend-only keys (never exposed to frontend)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # Used by /api/tts endpoint (nova voice, gpt-4o-mini-tts)

# Backend Connection URL (If using an external synchronization backend)
VITE_BACKEND_API_URL=https://moni-api.onrender.com/api

# Google Cloud Text-to-Speech API Key (Optional, falls back to local Web Speech API if empty)
VITE_GOOGLE_TTS_API_KEY=your_google_tts_api_key_here
